DATABASE_URL=postgresql+asyncpg://user:password@host:port/dbname
SECRET_KEY=change-me-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
UPLOAD_DIR=/app/uploads
